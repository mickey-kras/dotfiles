{{- /* Chezmoi config - bootstrap.sh is the primary path, but manual init should still work. */ -}}

{{- $userName := promptStringOnce . "user_name" "Display name for generated instructions" -}}
{{- $userRoleSummary := promptStringOnce . "user_role_summary" "Short role summary for generated instructions" -}}
{{- $userStackSummary := promptStringOnce . "user_stack_summary" "Current stack summary for generated instructions" -}}
{{- $obsidianVaultPath := promptStringOnce . "obsidian_vault_path" "Obsidian vault path (press Enter to use the default memory-vault path)" -}}
{{- $stitchApiKey := promptStringOnce . "stitch_api_key" "Stitch API key (press Enter to skip)" -}}

[data]
  user_name = {{ $userName | quote }}
  user_role_summary = {{ $userRoleSummary | quote }}
  user_stack_summary = {{ $userStackSummary | quote }}
  memory_provider = "obsidian"
  obsidian_vault_path = {{ $obsidianVaultPath | quote }}
  install_claude_code = "disabled"
  install_codex = "disabled"
  install_cursor = "disabled"
  install_gemini_cli = "disabled"
  install_droid = "disabled"
  stitch_api_key = {{ $stitchApiKey | quote }}
  bw_gate_install = "enabled"

{{- $runtime := includeTemplate "templates/resolved-state.json" . | fromJson -}}
{{- $resolved := $runtime.resolved -}}
{{- $servers := includeTemplate "templates/managed-mcp-servers.json" . | fromJson -}}
{{- $order := list
  "playwright"
  "context7"
  "figma"
  "stitch"
  "filesystem"
  "git"
  "shell"
  "terraform"
  "kubernetes"
  "process"
  "thinking"
  "memory"
  "obsidian"
  "http"
  "firebase"
  "github"
  "aws"
  "tailscale"
  "magic"
  "replicate"
  "MCP_DOCKER"
-}}
# Codex global configuration
# Managed by chezmoi - edit the template at ~/dotfiles/dot_codex/config.toml.tmpl

model = "gpt-5.4"
model_reasoning_effort = "medium"

{{- range $name := $order }}
{{- if hasKey $servers $name }}
{{- $server := index $servers $name }}

[mcp_servers.{{ $name }}]
{{- if hasKey $server "url" }}
type = "http"
url = {{ index $server "url" | toJson }}
{{- if hasKey $server "headers" }}
[mcp_servers.{{ $name }}.headers]
{{- $headers := index $server "headers" }}
{{- range $headerName, $headerValue := $headers }}
{{ $headerName | toJson }} = {{ $headerValue | toJson }}
{{- end }}
{{- end }}
{{- else }}
command = {{ index $server "command" | toJson }}
args = {{ index $server "args" | toJson }}
{{- if hasKey $server "env" }}
[mcp_servers.{{ $name }}.env]
{{- $env := index $server "env" }}
{{- range $envName, $envValue := $env }}
{{ $envName | toJson }} = {{ $envValue | toJson }}
{{- end }}
{{- end }}
{{- end }}
{{ end -}}
{{ end -}}

#!/usr/bin/env bash
set -euo pipefail

fail() {
  printf '%s\n' "$1" >&2
  exit 1
}

note() {
  printf '%s\n' "$1" >&2
}

bw_gate_helper() {
  printf '%s' "${BW_GATE_HELPER_PATH:-$HOME/.local/bin/bw-gate-helper}"
}

has_bw_gate() {
  [ "${BW_LOGIN_DISABLE_GATE:-0}" != "1" ] || return 1
  command -v bw-gate >/dev/null 2>&1 || return 1
  [ -x "$(bw_gate_helper)" ]
}

detect_bw_status() {
  local json status
  json="$(bw status 2>/dev/null || true)"
  status="$(printf '%s' "$json" | tr -d '\r\n ' | sed -n 's/.*"status":"\([^"]*\)".*/\1/p')"
  if [ -n "$status" ]; then
    printf '%s' "$status"
  else
    printf 'unauthenticated'
  fi
}

prompt_visible() {
  local prompt="$1"
  printf '%s' "$prompt"
  IFS= read -r REPLY
}

prompt_hidden() {
  local prompt="$1"
  local stty_state=""
  printf '%s' "$prompt"
  stty_state="$(stty -g 2>/dev/null || true)"
  if [ -n "$stty_state" ]; then
    stty -echo
  fi
  IFS= read -r REPLY
  if [ -n "$stty_state" ]; then
    stty "$stty_state"
  fi
  printf '\n'
}

choose_login_method() {
  if [ -n "${BW_CLIENTID:-}" ] && [ -n "${BW_CLIENTSECRET:-}" ]; then
    printf 'apikey'
    return 0
  fi

  printf 'Choose Bitwarden login method:\n'
  printf '  1. Email + password\n'
  printf '  2. API key\n'
  printf '  3. SSO\n'
  prompt_visible "Select [1/2/3] (default: 1): "
  case "${REPLY:-1}" in
    2) printf 'apikey' ;;
    3) printf 'sso' ;;
    *) printf 'password' ;;
  esac
}

perform_login() {
  local method="$1"
  case "$method" in
    apikey)
      printf 'Bitwarden API key login selected.\n'
      bw login --apikey
      ;;
    sso)
      printf 'Bitwarden SSO login selected.\n'
      bw login --sso
      ;;
    *)
      printf 'Bitwarden email/password login selected.\n'
      bw login
      ;;
  esac
}

write_session_file() {
  local session="$1"
  local session_path="$HOME/.bw_session"
  printf '%s\n' "$session" > "$session_path"
  chmod 600 "$session_path" 2>/dev/null || true
  printf 'BW_SESSION saved to %s\n' "$session_path"
}

unlock_bw() {
  local password="${BW_PASSWORD:-}"
  local session=""
  local tmpfile=""

  if [ -z "$password" ]; then
    prompt_hidden "Bitwarden master password: "
    password="$REPLY"
  fi

  [ -n "$password" ] || fail "ERROR: Bitwarden master password is required to unlock the vault."

  tmpfile="$(mktemp)"
  chmod 600 "$tmpfile" 2>/dev/null || true
  printf '%s\n' "$password" > "$tmpfile"

  if ! session="$(bw unlock --raw --passwordfile "$tmpfile")"; then
    rm -f "$tmpfile"
    return 1
  fi

  rm -f "$tmpfile"
  [ -n "$session" ] || fail "ERROR: Bitwarden unlock returned an empty session."
  write_session_file "$session"
}

main() {
  local status login_method force_refresh="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --refresh)
        force_refresh="true"
        ;;
      -h|--help|help)
        cat <<EOF
bw-login — refresh ~/.bw_session for Bitwarden-backed MCP wrappers

usage:
  bw-login [--refresh]

behavior:
  - on macOS, if bw-gate is installed, bw-login uses it
  - default: if bw-gate already has a cached token, load it via Touch ID/password into ~/.bw_session
  - --refresh: perform a fresh Bitwarden unlock and update the bw-gate cache

environment:
  BW_LOGIN_DISABLE_GATE=1   bypass bw-gate and use the legacy direct unlock flow
EOF
        exit 0
        ;;
      *)
        fail "ERROR: unknown argument: $1"
        ;;
    esac
    shift
  done

  if has_bw_gate; then
    if [ "$force_refresh" != "true" ] && "$(bw_gate_helper)" has >/dev/null 2>&1; then
      note "bw-login: authenticate with Touch ID or your Mac password to load the cached Bitwarden session into ~/.bw_session."
      bw-gate sync-file
      exit 0
    fi
    note "bw-login: refreshing BW_SESSION via bw-gate."
    bw-gate unlock --sync-file
    exit 0
  fi

  status="$(detect_bw_status)"

  if [ "$status" = "unauthenticated" ]; then
    printf 'Bitwarden login required.\n'
    login_method="$(choose_login_method)"
    perform_login "$login_method"
    status="$(detect_bw_status)"
  fi

  if [ "$status" = "unlocked" ] && [ -n "${BW_SESSION:-}" ]; then
    write_session_file "$BW_SESSION"
    exit 0
  fi

  if unlock_bw; then
    exit 0
  fi

  printf 'Existing Bitwarden CLI state may be stale or tied to a different login method.\n'
  prompt_visible "Reset Bitwarden CLI state with 'bw logout' and log in again? [Y/n]: "
  case "${REPLY:-Y}" in
    n|N)
      fail "ERROR: Failed to unlock Bitwarden vault. Check your master password and CLI login state."
      ;;
  esac

  bw logout || true
  login_method="$(choose_login_method)"
  perform_login "$login_method"
  unlock_bw || fail "ERROR: Failed to unlock Bitwarden vault after resetting login state."
}

main "$@"

#!/usr/bin/env node
import fs from "node:fs";
import os from "node:os";
import path from "node:path";
import { spawn, spawnSync } from "node:child_process";

function fail(message) {
  console.error(message);
  process.exit(1);
}

function getSession() {
  // Policy: the Bitwarden session must never live in a file on disk.
  //         It is resolved from the environment or from the Keychain
  //         via bw-gate-helper (Touch ID / Mac password gated).

  // 1. Process environment (inherited from a shell that already holds one).
  if (process.env.BW_SESSION) {
    return process.env.BW_SESSION.trim();
  }

  // 2. macOS Keychain via bw-gate-helper.
  if (process.platform === "darwin") {
    const helperPath = path.join(os.homedir(), ".local/bin/bw-gate-helper");
    if (fs.existsSync(helperPath)) {
      const helper = spawnSync(helperPath, ["get"], {
        encoding: "utf8",
        stdio: ["inherit", "pipe", "inherit"],
      });
      if (helper.status === 0 && helper.stdout) {
        return helper.stdout.trim();
      }
    }
  }

  return "";
}

function getField(item, fieldName) {
  if (fieldName === "password") {
    return item?.login?.password ?? "";
  }
  if (fieldName === "username") {
    return item?.login?.username ?? "";
  }
  const field = (item.fields || []).find((entry) => entry.name === fieldName);
  return field?.value ?? "";
}

function looksLikeUuid(value) {
  return /^[0-9a-fA-F-]{36}$/.test(value);
}

function runBw(args, session) {
  return spawnSync("bw", args, {
    encoding: "utf8",
    env: { ...process.env, BW_SESSION: session }
  });
}

function firstLine(text) {
  return String(text || "")
    .split(/\r?\n/)
    .map((line) => line.trim())
    .find(Boolean) || "";
}

function failForBwResult(result, action, itemRef) {
  const stdout = String(result?.stdout || "").trim();
  const stderr = String(result?.stderr || "").trim();
  const combined = [stderr, stdout].filter(Boolean).join("\n");
  const target = itemRef ? ` '${itemRef}'` : "";

  if (/you are not logged in|unauthenticated/i.test(combined)) {
    fail("ERROR: Bitwarden CLI is not logged in. Run 'bw login', then 'bw-gate unlock'.");
  }

  if (/vault is locked|master password|bw unlock|unlock your vault/i.test(combined)) {
    fail("ERROR: Bitwarden vault is locked. Run 'bw-gate unlock'.");
  }

  if (/invalid session|session key|mac failed|session has expired/i.test(combined)) {
    fail("ERROR: Bitwarden session is stale or invalid. Run 'bw-gate unlock'.");
  }

  const detail = firstLine(stderr) || firstLine(stdout);
  fail(`ERROR: Bitwarden returned unexpected output while ${action}${target}.${detail ? ` ${detail}` : ""}`);
}

function parseBwJson(result, action, itemRef) {
  try {
    return JSON.parse(result.stdout);
  } catch {
    failForBwResult(result, action, itemRef);
  }
}

function validateSession(session) {
  const status = runBw(["status", "--session", session], session);
  if (status.status !== 0) {
    failForBwResult(status, "checking status", "");
  }

  const payload = parseBwJson(status, "checking status", "");
  switch (payload?.status) {
    case "unlocked":
      return;
    case "locked":
      fail("ERROR: Bitwarden vault is locked. Run 'bw-gate unlock'.");
      break;
    case "unauthenticated":
      fail("ERROR: Bitwarden CLI is not logged in. Run 'bw login', then 'bw-gate unlock'.");
      break;
    default:
      return;
  }
}

function resolveItem(itemRef, session) {
  if (looksLikeUuid(itemRef)) {
    const direct = runBw(["get", "item", itemRef, "--session", session], session);
    if (direct.status !== 0) {
      failForBwResult(direct, "fetching item", itemRef);
    }
    return parseBwJson(direct, "fetching item", itemRef);
  }

  const listed = runBw(["list", "items", "--search", itemRef, "--session", session], session);
  if (listed.status !== 0) {
    failForBwResult(listed, "searching for item", itemRef);
  }

  const items = parseBwJson(listed, "searching for item", itemRef);

  const exactMatches = items.filter((item) => item?.name === itemRef);
  if (exactMatches.length === 0) {
    fail(`ERROR: Bitwarden item '${itemRef}' was not found.`);
  }
  if (exactMatches.length > 1) {
    const ids = exactMatches.map((item) => `${item.id} (${item.name})`).join(", ");
    fail(`ERROR: Multiple Bitwarden items matched '${itemRef}'. Use a unique item name or item id. Matches: ${ids}`);
  }

  const resolvedId = exactMatches[0].id;
  const direct = runBw(["get", "item", resolvedId, "--session", session], session);
  if (direct.status !== 0) {
    failForBwResult(direct, "fetching item", resolvedId);
  }
  return parseBwJson(direct, "fetching item", resolvedId);
}

const args = process.argv.slice(2);
if (args.length < 4) {
  fail("Usage: bw-mcp <bw-item-name> <ENV_VAR=field,...> -- <command> [args...]");
}

const itemName = args[0];
const mapping = args[1];
let commandIndex = 2;
if (args[2] === "--") {
  commandIndex = 3;
}
const command = args[commandIndex];
const commandArgs = args.slice(commandIndex + 1);
if (!command) {
  fail("ERROR: Missing wrapped command.");
}

const session = getSession();
if (!session) {
  fail("ERROR: Bitwarden session not found. Run 'bw-gate unlock' (macOS Keychain) or set $BW_SESSION in the environment.");
}

validateSession(session);

const item = resolveItem(itemName, session);

const childEnv = { ...process.env, BW_SESSION: session };
for (const entry of mapping.split(",")) {
  if (!entry) {
    continue;
  }
  const separatorIndex = entry.indexOf("=");
  if (separatorIndex <= 0) {
    fail(`ERROR: Invalid env mapping '${entry}'.`);
  }
  const envName = entry.slice(0, separatorIndex);
  const fieldName = entry.slice(separatorIndex + 1);
  const value = getField(item, fieldName);
  if (!value) {
    fail(`ERROR: Bitwarden item '${itemName}' is missing '${fieldName}'.`);
  }
  childEnv[envName] = value;
}

const child = spawn(command, commandArgs, {
  stdio: "inherit",
  env: childEnv
});

child.on("error", (error) => {
  fail(`ERROR: Failed to start '${command}': ${error.message}`);
});

child.on("exit", (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal);
  } else {
    process.exit(code ?? 1);
  }
});

// Proxy signals to child
const signals = ["SIGINT", "SIGTERM", "SIGHUP"];
for (const sig of signals) {
  process.on(sig, () => {
    if (!child.killed) {
      child.kill(sig);
    }
  });
}

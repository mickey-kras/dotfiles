#!/usr/bin/env node
import fs from "node:fs";
import os from "node:os";
import path from "node:path";
import { spawnSync } from "node:child_process";

function fail(message) {
  console.error(message);
  process.exit(1);
}

function getSession() {
  if (process.env.BW_SESSION) {
    return process.env.BW_SESSION.trim();
  }
  const sessionPath = path.join(os.homedir(), ".bw_session");
  if (fs.existsSync(sessionPath)) {
    return fs.readFileSync(sessionPath, "utf8").trim();
  }
  return "";
}

function getField(item, fieldName) {
  if (fieldName === "password") {
    return item?.login?.password ?? "";
  }
  if (fieldName === "username") {
    return item?.login?.username ?? "";
  }
  const field = (item.fields || []).find((entry) => entry.name === fieldName);
  return field?.value ?? "";
}

function looksLikeUuid(value) {
  return /^[0-9a-fA-F-]{36}$/.test(value);
}

function runBw(args, session) {
  return spawnSync("bw", args, {
    encoding: "utf8",
    env: { ...process.env, BW_SESSION: session }
  });
}

function resolveItem(itemRef, session) {
  if (looksLikeUuid(itemRef)) {
    const direct = runBw(["get", "item", itemRef, "--session", session], session);
    if (direct.status !== 0) {
      fail((direct.stderr || `ERROR: Could not fetch Bitwarden item '${itemRef}'.`).trim());
    }
    try {
      return JSON.parse(direct.stdout);
    } catch (error) {
      fail(`ERROR: Failed to parse Bitwarden item '${itemRef}': ${error.message}`);
    }
  }

  const listed = runBw(["list", "items", "--search", itemRef, "--session", session], session);
  if (listed.status !== 0) {
    fail((listed.stderr || `ERROR: Could not search Bitwarden for '${itemRef}'.`).trim());
  }

  let items;
  try {
    items = JSON.parse(listed.stdout);
  } catch (error) {
    fail(`ERROR: Failed to parse Bitwarden search results for '${itemRef}': ${error.message}`);
  }

  const exactMatches = items.filter((item) => item?.name === itemRef);
  if (exactMatches.length === 0) {
    fail(`ERROR: Bitwarden item '${itemRef}' was not found.`);
  }
  if (exactMatches.length > 1) {
    const ids = exactMatches.map((item) => `${item.id} (${item.name})`).join(", ");
    fail(`ERROR: Multiple Bitwarden items matched '${itemRef}'. Use a unique item name or item id. Matches: ${ids}`);
  }

  const resolvedId = exactMatches[0].id;
  const direct = runBw(["get", "item", resolvedId, "--session", session], session);
  if (direct.status !== 0) {
    fail((direct.stderr || `ERROR: Could not fetch Bitwarden item '${resolvedId}'.`).trim());
  }
  try {
    return JSON.parse(direct.stdout);
  } catch (error) {
    fail(`ERROR: Failed to parse Bitwarden item '${resolvedId}': ${error.message}`);
  }
}

const args = process.argv.slice(2);
if (args.length < 4) {
  fail("Usage: bw-mcp <bw-item-name> <ENV_VAR=field,...> -- <command> [args...]");
}

const itemName = args[0];
const mapping = args[1];
let commandIndex = 2;
if (args[2] === "--") {
  commandIndex = 3;
}
const command = args[commandIndex];
const commandArgs = args.slice(commandIndex + 1);
if (!command) {
  fail("ERROR: Missing wrapped command.");
}

const session = getSession();
if (!session) {
  fail("ERROR: Bitwarden session not found. Run bw-login or write a valid token to ~/.bw_session.");
}

const item = resolveItem(itemName, session);

const childEnv = { ...process.env, BW_SESSION: session };
for (const entry of mapping.split(",")) {
  if (!entry) {
    continue;
  }
  const separatorIndex = entry.indexOf("=");
  if (separatorIndex <= 0) {
    fail(`ERROR: Invalid env mapping '${entry}'.`);
  }
  const envName = entry.slice(0, separatorIndex);
  const fieldName = entry.slice(separatorIndex + 1);
  const value = getField(item, fieldName);
  if (!value) {
    fail(`ERROR: Bitwarden item '${itemName}' is missing '${fieldName}'.`);
  }
  childEnv[envName] = value;
}

const child = spawnSync(command, commandArgs, {
  stdio: "inherit",
  env: childEnv
});

if (child.error) {
  fail(`ERROR: Failed to start '${command}': ${child.error.message}`);
}
process.exit(child.status ?? 1);

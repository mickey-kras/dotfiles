#!/usr/bin/env bash
# chezmoi:template:left-delimiter="# {{" right-delimiter="}}"
# Registers MCP servers in Claude Code via `claude mcp add --scope user`.
# Idempotent: removes then re-adds each server.
# Re-runs only when template output changes (chezmoi run_onchange_).
#
# hash: # {{ include "dot_cursor/mcp.json.tmpl" | sha256sum }}

set -uo pipefail

command -v claude >/dev/null 2>&1 || { echo "claude CLI not found, skipping MCP setup"; exit 0; }

echo "Configuring Claude Code MCP servers..."

FAILED=0

add_mcp() {
  local name="$1"; shift
  claude mcp remove --scope user "$name" 2>/dev/null || true
  if claude mcp add --scope user "$@" 2>/dev/null; then
    echo "  + $name"
  else
    echo "  ! $name (failed)"
    FAILED=$((FAILED + 1))
  fi
}

# Core MCPs (always installed)
add_mcp playwright playwright -- npx -y @playwright/mcp@latest
add_mcp context7 --transport http context7 "https://mcp.context7.com/mcp"

# {{ if .enable_api_mcps }}
# API-key MCPs (keys from Bitwarden)
add_mcp exa -e "EXA_API_KEY=# {{ (bitwarden "item" "exa-api-key").login.password }}" exa -- npx -y exa-mcp-server
add_mcp firecrawl -e "FIRECRAWL_API_KEY=# {{ (bitwarden "item" "firecrawl-api-key").login.password }}" firecrawl -- npx -y firecrawl-mcp
add_mcp fal-ai -e "FAL_KEY=# {{ (bitwarden "item" "fal-api-key").login.password }}" fal-ai -- npx -y fal-ai-mcp-server
# {{ end }}

echo ""
if [ "$FAILED" -eq 0 ]; then
  echo "All MCPs configured."
else
  echo "$FAILED MCP(s) failed. Re-run 'chezmoi apply' or add manually."
fi

exit 0

{{- $home := replace "\\" "/" .chezmoi.homeDir -}}
{{- $runtime := includeTemplate "templates/resolved-state.json" . | fromJson -}}
{{- $resolved := $runtime.resolved -}}
{{- $selectedMcps := index $resolved "mcps" "enabled" -}}
{{- $settings := index $resolved "settings" -}}
{{- $servers := dict -}}

{{- if has "playwright" $selectedMcps -}}
  {{- $_ := set $servers "playwright" (dict "command" "npx" "args" (list "-y" "@playwright/mcp@0.0.68")) -}}
{{- end -}}
{{- if has "context7" $selectedMcps -}}
  {{- $_ := set $servers "context7" (dict "url" "https://mcp.context7.com/mcp") -}}
{{- end -}}
{{- if has "figma" $selectedMcps -}}
  {{- $_ := set $servers "figma" (dict "url" "https://mcp.figma.com/mcp") -}}
{{- end -}}
{{- if and (has "stitch" $selectedMcps) (lookPath "bw") -}}
  {{- $_ := set $servers "stitch" (dict
    "command" "node"
    "args" (list
      (printf "%s/.local/bin/bw-mcp" $home)
      "mcp-stitch"
      "STITCH_API_KEY=API_KEY"
      "--"
      "/bin/bash"
      "-c"
      "exec npx -y mcp-remote@latest https://stitch.googleapis.com/mcp --header \"X-Goog-Api-Key:$STITCH_API_KEY\" 2> >(grep --line-buffered -v 'Using custom headers' >&2)"
    )
  ) -}}
{{- end -}}
{{- if has "filesystem" $selectedMcps -}}
  {{- $_ := set $servers "filesystem" (dict "command" "npx" "args" (list "-y" "@modelcontextprotocol/server-filesystem@2026.1.14" (printf "%s/Dev" $home))) -}}
{{- end -}}
{{- if has "git" $selectedMcps -}}
  {{- $_ := set $servers "git" (dict "command" "npx" "args" (list "-y" "@cyanheads/git-mcp-server@2.10.5")) -}}
{{- end -}}
{{- if has "shell" $selectedMcps -}}
  {{- $_ := set $servers "shell" (dict "command" "npx" "args" (list "-y" "super-shell-mcp@2.0.15")) -}}
{{- end -}}
{{- if has "terraform" $selectedMcps -}}
  {{- $_ := set $servers "terraform" (dict "command" "npx" "args" (list "-y" "terraform-mcp-server@0.13.0")) -}}
{{- end -}}
{{- if has "kubernetes" $selectedMcps -}}
  {{- $_ := set $servers "kubernetes" (dict "command" "npx" "args" (list "-y" "mcp-server-kubernetes@3.4.0")) -}}
{{- end -}}
{{- if has "process" $selectedMcps -}}
  {{- $_ := set $servers "process" (dict "command" "npx" "args" (list "-y" "@ai-capabilities-suite/mcp-process@1.5.10")) -}}
{{- end -}}
{{- if has "thinking" $selectedMcps -}}
  {{- $_ := set $servers "thinking" (dict "command" "npx" "args" (list "-y" "@modelcontextprotocol/server-sequential-thinking@2025.12.18")) -}}
{{- end -}}
{{- if has "memory" $selectedMcps -}}
  {{- if and (eq (index $settings "memory_provider") "obsidian") (index $settings "obsidian_vault_path") -}}
    {{- $_ := set $servers "memory" (dict "command" "npx" "args" (list "-y" "@bitbonsai/mcpvault@latest" (index $settings "obsidian_vault_path"))) -}}
  {{- else -}}
    {{- $_ := set $servers "memory" (dict "command" "npx" "args" (list "-y" "@modelcontextprotocol/server-memory@2026.1.26")) -}}
  {{- end -}}
{{- end -}}
{{- if and (has "obsidian" $selectedMcps) (index $settings "obsidian_vault_path") (lookPath "bw") -}}
  {{- $_ := set $servers "obsidian" (dict
    "command" "node"
    "args" (list (printf "%s/.local/bin/bw-mcp" $home) "mcp-obsidian" "OBSIDIAN_API_KEY=API Key" "--" "npx" "-y" "obsidian-mcp-server")
    "env" (dict
      "OBSIDIAN_BASE_URL" "https://127.0.0.1:27124"
      "OBSIDIAN_VERIFY_SSL" "false"
      "OBSIDIAN_ENABLE_CACHE" "true"
      "OBSIDIAN_VAULT_PATH" (index $settings "obsidian_vault_path")
    )
  ) -}}
{{- end -}}
{{- if and (has "http" $selectedMcps) (lookPath "uvx") -}}
  {{- $_ := set $servers "http" (dict "command" "uvx" "args" (list "mcp-server-fetch==2025.4.7")) -}}
{{- end -}}
{{- if and (has "firebase" $selectedMcps) (lookPath "firebase") -}}
  {{- $_ := set $servers "firebase" (dict "command" "firebase" "args" (list "experimental:mcp")) -}}
{{- end -}}
{{- if and (has "github" $selectedMcps) (lookPath "bw") -}}
  {{- $_ := set $servers "github" (dict "command" "node" "args" (list (printf "%s/.local/bin/bw-mcp" $home) "mcp-github" "GITHUB_PERSONAL_ACCESS_TOKEN=GITHUB_PERSONAL_ACCESS_TOKEN" "--" "npx" "-y" "@modelcontextprotocol/server-github@2025.4.8")) -}}
{{- end -}}
{{- if and (has "aws" $selectedMcps) (lookPath "bw") (lookPath "uvx") -}}
  {{- $_ := set $servers "aws" (dict "command" "node" "args" (list (printf "%s/.local/bin/bw-mcp" $home) "mcp-aws" "AWS_ACCESS_KEY_ID=AWS_ACCESS_KEY_ID,AWS_SECRET_ACCESS_KEY=AWS_SECRET_ACCESS_KEY" "--" "uvx" "awslabs.aws-api-mcp-server==1.3.26")) -}}
{{- end -}}
{{- if and (has "tailscale" $selectedMcps) (lookPath "bw") -}}
  {{- $_ := set $servers "tailscale" (dict "command" "node" "args" (list (printf "%s/.local/bin/bw-mcp" $home) "mcp-tailscale" "TAILSCALE_API_KEY=TAILSCALE_API_KEY,TAILSCALE_TAILNET=TAILSCALE_TAILNET" "--" (printf "%s/.local/bin/tailscale-mcp-server" $home))) -}}
{{- end -}}
{{- if and (has "magic" $selectedMcps) (lookPath "bw") -}}
  {{- $_ := set $servers "magic" (dict "command" "node" "args" (list (printf "%s/.local/bin/bw-mcp" $home) "mcp-magic" "API_KEY=MAGIC_API_KEY" "--" "npx" "-y" "@21st-dev/magic@latest")) -}}
{{- end -}}
{{- if and (has "replicate" $selectedMcps) (lookPath "bw") -}}
  {{- $_ := set $servers "replicate" (dict "command" "node" "args" (list (printf "%s/.local/bin/bw-mcp" $home) "mcp-replicate" "REPLICATE_API_TOKEN=token" "--" "npx" "-y" "replicate-mcp")) -}}
{{- end -}}
{{- if and (has "docker" $selectedMcps) (lookPath "docker") -}}
  {{- $_ := set $servers "MCP_DOCKER" (dict "command" "docker" "args" (list "mcp" "gateway" "run")) -}}
{{- end -}}

{{- $servers | toPrettyJson -}}

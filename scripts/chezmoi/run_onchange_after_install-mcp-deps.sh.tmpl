#!/usr/bin/env bash
# Installs system tools required by selected MCP servers.
# Each missing tool is shown with its purpose, the MCP that needs it, and the
# exact command that will run; user confirms per-tool before anything installs.
# Set DOTFILES_ASSUME_YES=1 to auto-confirm every prompt (for CI / scripted runs).
#
# hash: {{ include "templates/resolved-state.json" | sha256sum }}

set -euo pipefail

{{ $runtime := includeTemplate "templates/resolved-state.json" . | fromJson -}}
{{ $resolved := $runtime.resolved -}}
ENABLED_MCPS=(
{{- range index $resolved "mcps" "enabled" }}
  "{{ . }}"
{{- end }}
)

is_enabled() {
  local needle="$1" item
  for item in "${ENABLED_MCPS[@]}"; do
    [ "$item" = "$needle" ] && return 0
  done
  return 1
}

# Each candidate dep is a 5-field record separated by '|':
#   1. binary to check (presence => skip)
#   2. human-readable label
#   3. comma-separated list of MCPs that require it
#   4. one-line purpose
#   5. install command (run via eval)
CANDIDATES=()

if is_enabled aws || is_enabled http; then
  NEEDED_BY=""
  is_enabled aws  && NEEDED_BY="aws"
  is_enabled http && NEEDED_BY="${NEEDED_BY:+$NEEDED_BY, }http"
  if [[ "$(uname -s)" == "Darwin" ]] && command -v brew >/dev/null 2>&1; then
    INSTALL_CMD="brew install uv"
  else
    INSTALL_CMD="curl -LsSf https://astral.sh/uv/install.sh | sh"
  fi
  CANDIDATES+=("uvx|uv (provides uvx)|${NEEDED_BY}|Python tool runner; the wrappers for the aws/http MCPs invoke 'uvx ...' to spawn the actual server|${INSTALL_CMD}")
fi

if is_enabled firebase; then
  if command -v npm >/dev/null 2>&1; then
    INSTALL_CMD="npm install -g firebase-tools"
  elif [[ "$(uname -s)" == "Darwin" ]] && command -v brew >/dev/null 2>&1; then
    INSTALL_CMD="brew install firebase-cli"
  else
    INSTALL_CMD=""
  fi
  if [ -n "$INSTALL_CMD" ]; then
    CANDIDATES+=("firebase|firebase-tools|firebase|Firebase CLI; the firebase MCP shells out to 'firebase ...' for project operations|${INSTALL_CMD}")
  fi
fi

# Filter to only deps that are actually missing
MISSING=()
for rec in "${CANDIDATES[@]}"; do
  IFS='|' read -r bin _ _ _ _ <<< "$rec"
  if ! command -v "$bin" >/dev/null 2>&1; then
    MISSING+=("$rec")
  fi
done

if [ ${#MISSING[@]} -eq 0 ]; then
  exit 0
fi

# Color codes (also disabled when stdout is not a TTY)
if [ -t 1 ]; then
  C=$'\033[1;36m'; G=$'\033[1;32m'; Y=$'\033[1;33m'; D=$'\033[0;90m'; B=$'\033[1;37m'; R=$'\033[0m'
else
  C=""; G=""; Y=""; D=""; B=""; R=""
fi

printf '\n'
printf '%sMCP runtime dependencies%s\n' "$B" "$R"
printf '%s%d %s missing on this machine. Each is gated by which MCPs you have enabled,%s\n' "$D" "${#MISSING[@]}" "$([ ${#MISSING[@]} -eq 1 ] && echo 'tool is' || echo 'tools are')" "$R"
printf '%sand will only be needed if you actually use those MCPs.%s\n' "$D" "$R"
printf '%sYou will be asked separately for each one.%s\n\n' "$D" "$R"

# Auto-confirm flag (read once)
ASSUME_YES="${DOTFILES_ASSUME_YES:-0}"

has_tty() {
  [ -t 0 ] && [ -t 1 ]
}

prompt_confirm() {
  local prompt="$1"
  if [ "$ASSUME_YES" = "1" ]; then
    printf '%s [auto-yes]\n' "$prompt"
    REPLY="y"
    return
  fi
  if ! has_tty; then
    printf '%s [no TTY; skipping]\n' "$prompt"
    REPLY="n"
    return
  fi
  printf '%s' "$prompt"
  read -r REPLY || REPLY="n"
}

idx=0
total=${#MISSING[@]}
for rec in "${MISSING[@]}"; do
  idx=$((idx + 1))
  IFS='|' read -r bin label needed_by purpose install_cmd <<< "$rec"

  printf '%s[%d/%d] %s%s%s\n' "$D" "$idx" "$total" "$C" "$label" "$R"
  printf '       %sRequired by MCP:%s %s\n' "$D" "$R" "$needed_by"
  printf '       %sPurpose:%s         %s\n' "$D" "$R" "$purpose"
  printf '       %sInstall command:%s %s\n' "$D" "$R" "$install_cmd"

  prompt_confirm "       ${Y}Install now? [y/N]: ${R}"
  case "$REPLY" in
    [yY]|[yY][eE][sS])
      printf '       %s>%s running install...\n' "$Y" "$R"
      if eval "$install_cmd" >/tmp/install-mcp-deps-$$.log 2>&1; then
        printf '       %s+%s installed %s\n\n' "$G" "$R" "$label"
      else
        printf '       %sx%s install failed for %s (see /tmp/install-mcp-deps-%d.log)\n\n' "$Y" "$R" "$label" "$$"
      fi
      ;;
    *)
      printf '       %s>%s skipped; install manually later with: %s%s%s\n\n' "$D" "$R" "$C" "$install_cmd" "$R"
      ;;
  esac
done
